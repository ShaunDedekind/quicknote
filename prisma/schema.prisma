// Prisma schema for QuickNote
// PostgreSQL (Neon) — enums are fully supported

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum NoteSource {
  TEXT
  AUDIO
}

enum NoteType {
  TASK
  REMINDER
  EVENT
  INFO
}

enum NoteCategory {
  WORK
  PERSONAL
  HEALTH
  FINANCE
  OTHER
}

enum NoteStatus {
  PENDING
  EXPANDED
  DISMISSED
  DONE
  ERROR
}

// ---------------------------------------------------------------------------
// NextAuth required models
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  notes         Note[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Core domain models
// ---------------------------------------------------------------------------

model Note {
  id      String  @id @default(cuid())
  userId  String?
  user    User?   @relation(fields: [userId], references: [id])

  // Raw input
  rawContent String
  source     NoteSource

  // AI-expanded fields — null until status = EXPANDED
  title       String?
  description String?
  type        NoteType?
  category    NoteCategory?
  dueDate     DateTime?
  reminderAt  DateTime?

  // Relational nudge schedule (one row per nudge)
  nudgeSchedule NudgeSchedule[]

  // Correction history
  corrections Correction[]

  // Calendar integration
  calendarEventId     String?  // Google Calendar event ID after creation
  calendarWorthy      Boolean  @default(false)
  suggestedEventTitle String?
  suggestedDuration   Int?     // minutes
  suggestedAttendees  String?  // JSON-encoded string[]

  // Lifecycle
  status    NoteStatus @default(PENDING)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model NudgeSchedule {
  id          String   @id @default(cuid())
  noteId      String
  note        Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  scheduledAt DateTime

  @@index([noteId])
}

// One row per changed field per correction submission.
// Accumulates over time as a personalisation signal.
model Correction {
  id             String   @id @default(cuid())
  noteId         String
  note           Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  correctionText String
  rawInput       String
  fieldChanged   String
  oldValue       String
  newValue       String
  createdAt      DateTime @default(now())

  @@index([noteId])
}
